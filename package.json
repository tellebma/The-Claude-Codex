{
  "name": "the-claude-codex",
  "version": "1.3.0",
  "private": true,
  "description": "The Claude Codex - Guide de reference pour maitriser Claude Code",
  "scripts": {
    "dev": "next dev",
    "build:llms": "node scripts/generate-llms-txt.ts",
    "build:search-index": "node scripts/generate-search-index.ts",
    "prebuild": "npm run build:search-index && npm run build:llms",
    "build": "next build",
    "validate:static": "node scripts/validate-static-output.ts",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "sonar:local": "docker run --rm -e SONAR_HOST_URL=\"${SONAR_HOST_URL:-http://host.docker.internal:9000}\" -e SONAR_TOKEN=\"${SONAR_TOKEN}\" -v \"$(pwd):/usr/src\" sonarsource/sonar-scanner-cli",
    "test:mutation": "stryker run",
    "docker:build": "docker build -t tellebma/the-claude-codex .",
    "docker:push": "docker push tellebma/the-claude-codex",
    "docker:release": "npm run docker:build && npm run docker:push"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.14.0",
    "next": "^14.2.35",
    "next-intl": "^4.9.1",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.4",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "glob": "^10.5.0",
    "flatted": "^3.4.2"
  }
}
