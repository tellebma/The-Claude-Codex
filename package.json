{
  "name": "the-claude-codex",
  "version": "1.8.0",
  "private": true,
  "description": "The Claude Codex - Guide de reference pour maitriser Claude Code",
  "scripts": {
    "dev": "next dev",
    "build:llms": "node scripts/generate-llms-txt.ts",
    "build:og": "tsx scripts/generate-og-png.ts",
    "build:search-index": "node scripts/generate-search-index.ts",
    "prebuild": "npm run build:search-index && npm run build:llms",
    "build": "next build",
    "validate:static": "node scripts/validate-static-output.ts",
    "audit:links": "node scripts/audit-internal-links.ts",
    "check:contrast": "tsx scripts/check-contrast.ts",
    "check:hex": "./scripts/check-hardcoded-colors.sh",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "sonar:local": "docker run --rm -e SONAR_HOST_URL=\"${SONAR_HOST_URL:-http://host.docker.internal:9000}\" -e SONAR_TOKEN=\"${SONAR_TOKEN}\" -v \"$(pwd):/usr/src\" sonarsource/sonar-scanner-cli",
    "test:mutation": "stryker run",
    "docker:build": "docker build -t tellebma/the-claude-codex .",
    "docker:push": "docker push tellebma/the-claude-codex",
    "docker:release": "npm run docker:build && npm run docker:push"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "^0.4.6",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.12",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "picomatch": "^4.0.4",
    "glob": "^10.5.0",
    "flatted": "^3.4.2",
    "react": "$react",
    "react-dom": "$react-dom"
  }
}
