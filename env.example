# Matomo Analytics (optional — tracking disabled when not set)
NEXT_PUBLIC_MATOMO_URL=https://your-matomo-instance.example.com
NEXT_PUBLIC_MATOMO_SITE_ID=1

# Matomo Database (only needed if self-hosting Matomo alongside the site)
MATOMO_DB_PASSWORD=your_strong_db_password_here
MATOMO_DB_ROOT_PASSWORD=your_strong_root_password_here
MATOMO_DB_USER=matomo
MATOMO_DB_NAME=matomo

# Nginx CSP — Matomo origin for Content-Security-Policy header
# Used by envsubst in the Docker entrypoint
MATOMO_ORIGIN=https://your-matomo-instance.example.com
