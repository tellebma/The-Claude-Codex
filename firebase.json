{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
          { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://matomo.tellebma.fr; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://img.youtube.com https://matomo.tellebma.fr; frame-src https://www.youtube-nocookie.com; connect-src 'self' https://matomo.tellebma.fr;"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|svg|png|jpg|jpeg|webp|woff|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "redirects": [
      { "source": "/", "destination": "/fr/", "type": 301 },
      { "source": "/en/content/bonnes-pratiques-securite", "destination": "/en/content/security-best-practices/", "type": 301 },
      { "source": "/en/content/bonnes-pratiques-securite/", "destination": "/en/content/security-best-practices/", "type": 301 },
      { "source": "/en/content/mythes-claude-code", "destination": "/en/content/claude-code-myths/", "type": 301 },
      { "source": "/en/content/mythes-claude-code/", "destination": "/en/content/claude-code-myths/", "type": 301 },
      { "source": "/en/content/couts-reels-claude-code", "destination": "/en/content/real-costs-claude-code/", "type": 301 },
      { "source": "/en/content/couts-reels-claude-code/", "destination": "/en/content/real-costs-claude-code/", "type": 301 },
      { "source": "/en/mcp/securite-mcp", "destination": "/en/mcp/mcp-security/", "type": 301 },
      { "source": "/en/mcp/securite-mcp/", "destination": "/en/mcp/mcp-security/", "type": 301 },
      {
        "regex": "^/(about|advanced|agents|configurator|content|design-system|ecosystem|enterprise|future|getting-started|glossary|limits|mcp|personas|plugins|prompting|reference|skills|use-cases)/?$",
        "destination": "/fr/:1/",
        "type": 301
      },
      {
        "regex": "^/(about|advanced|agents|configurator|content|design-system|ecosystem|enterprise|future|getting-started|glossary|limits|mcp|personas|plugins|prompting|reference|skills|use-cases)/(.+?)/?$",
        "destination": "/fr/:1/:2/",
        "type": 301
      }
    ]
  }
}
